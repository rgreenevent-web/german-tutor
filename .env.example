# ---- Copy this file to ".env" and fill in your own keys ----

# Anthropic (the teaching brain) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Model for lessons. claude-sonnet-5 = great quality. claude-haiku-4-5 = cheaper/faster.
ANTHROPIC_MODEL=claude-sonnet-5

# ElevenLabs (German audio) — https://elevenlabs.io/
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxx
# Pick a German-capable voice from your ElevenLabs voice library and paste its ID here.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI (Marathi speech-to-text via Whisper) — https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

PORT=3000
